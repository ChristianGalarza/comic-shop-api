// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING // Added to cart or pending payment
  PAID // Payment has been completed
  SHIPPED // Order has been shipped
  DELIVERED // Order has been delivered
  CANCELLED // Order has been cancelled
}

enum PullStatus {
  PENDING_PAYMENT //Added to pull list waiting for payment
  PAID // Payment has been completed, copy is reserved
  FULLFILLED // Comic arrived ready for delivery and removed from inventory
  CANCELLED // Paid not received within a reasonable time or customer requested cancellation
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
  pullRequest PullRequest[]
  addresses   Address[]
}

model Address {
  id         Int     @id @default(autoincrement())
  street     String
  city       String
  state      String
  zipCode    String
  country    String  @default("México")
  references String?

  isDefault Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id     Int         @id @default(autoincrement())
  status OrderStatus @default(PENDING)
  total  Float // Total price of the order

  // User relation
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // Ordered items
  items OrderItem[]

  shippingAddress String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PullRequest {
  id       Int        @id @default(autoincrement())
  status   PullStatus @default(PENDING_PAYMENT)
  quantity Int        @default(1)

  paidAt DateTime?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float // Price at the time of order

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id])
}

model Comic {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  imageUrl    String
  releaseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  //Writer Relation
  writerId Int
  writer   Person @relation("ComicWriter", fields: [writerId], references: [id])

  //Drawer Relation
  drawerId Int
  drawer   Person @relation("ComicDrawer", fields: [drawerId], references: [id])

  //Cover Artist Relation
  coverArtistId Int
  coverArtist   Person @relation("ComicCoverArtist", fields: [coverArtistId], references: [id])

  //Publisher Relation
  publisherId Int
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  //Inventory Relation(1:1)
  inventory    Inventory?
  orderItems   OrderItem[]
  pullRequests PullRequest[]
}

model Person {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  isWriter      Boolean
  isDrawer      Boolean
  //Inverted Relation
  writtenComics Comic[]  @relation("ComicWriter")
  drawnComics   Comic[]  @relation("ComicDrawer")
  coverComics   Comic[]  @relation("ComicCoverArtist")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Publisher {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  //Comic Relation
  comics Comic[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inventory {
  id       Int @id @default(autoincrement())
  quantity Int @default(0)

  //Foreign key(comic_id)
  comicId Int   @unique
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
